# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sevasync?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT Secrets (CHANGE THESE IN PRODUCTION!)
ACCESS_TOKEN_SECRET="your-super-secret-access-token-key-change-this"
REFRESH_TOKEN_SECRET="your-super-secret-refresh-token-key-change-this"

# Encryption Key (32 bytes, generate with: openssl rand -hex 32)
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# Twilio/Exotel (for IVR)
TWILIO_ACCOUNT_SID="your_account_sid"
TWILIO_AUTH_TOKEN="your_auth_token"
TWILIO_PHONE_NUMBER="+1234567890"

# Server
PORT=3000
NODE_ENV="development"

# CORS
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:5174"
