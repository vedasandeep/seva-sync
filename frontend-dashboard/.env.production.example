# ============================================
# SEVASYNC DASHBOARD - PRODUCTION ENVIRONMENT
# ============================================
#
# This file configures the React Vite frontend for production.
#
# Copy this as .env.production.local and fill in actual URLs.
#
# REQUIRED for Production:
# - VITE_API_URL: Backend API URL (Render)
# - VITE_SOCKET_URL: WebSocket URL (Render backend)
#

# ============================================
# API CONFIGURATION
# ============================================
# Backend API URL (from Render deployment)
# Must match your backend BASE_URL
VITE_API_URL="https://sevasync-api.render.com"

# WebSocket URL for real-time updates
# Same as API URL (Socket.io uses same host)
VITE_SOCKET_URL="https://sevasync-api.render.com"

# ============================================
# DEVELOPMENT HELPERS (set to false in prod)
# ============================================
VITE_DEBUG_MODE="false"
VITE_LOG_LEVEL="info"

# ============================================
# FEATURE FLAGS
# ============================================
# Enable/disable features
VITE_ENABLE_IVR="true"
VITE_ENABLE_OFFLINE_MODE="true"
VITE_ENABLE_ANALYTICS="true"

# ============================================
# NOTES
# ============================================
#
# 1. VITE_API_URL:
#    - Must be the Render backend URL
#    - Must include https://
#    - No trailing slash
#    - Example: https://sevasync-api.render.com
#
# 2. VITE_SOCKET_URL:
#    - Same as VITE_API_URL (Socket.io uses same host)
#    - Socket.io auto-configures the upgrade
#
# 3. Update when:
#    - Backend URL changes
#    - Moving to production deployment
#    - Changing API provider
#
# 4. Test after updating:
#    - Open browser DevTools (F12)
#    - Go to Network tab
#    - Verify API calls go to correct URL
#    - Check WebSocket connections (look for 'socket.io')
#
