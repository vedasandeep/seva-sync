# ============================================
# SEVASYNC PWA - PRODUCTION ENVIRONMENT
# ============================================
#
# This file configures the React Vite PWA for production.
#
# Copy this as .env.production.local and fill in actual URLs.
#
# REQUIRED for Production:
# - VITE_API_URL: Backend API URL (Render)
# - VITE_SOCKET_URL: WebSocket URL (Render backend)
#

# ============================================
# API CONFIGURATION
# ============================================
# Backend API URL (from Render deployment)
# Must match your backend BASE_URL
VITE_API_URL="https://sevasync-api.render.com"

# WebSocket URL for real-time updates
# Same as API URL (Socket.io uses same host)
VITE_SOCKET_URL="https://sevasync-api.render.com"

# ============================================
# PWA SPECIFIC SETTINGS
# ============================================
# Service worker configuration
VITE_ENABLE_SERVICE_WORKER="true"

# Offline sync
VITE_ENABLE_OFFLINE_SYNC="true"

# Push notifications
VITE_ENABLE_PUSH_NOTIFICATIONS="true"

# ============================================
# DEVELOPMENT HELPERS (set to false in prod)
# ============================================
VITE_DEBUG_MODE="false"
VITE_LOG_LEVEL="info"

# ============================================
# FEATURE FLAGS
# ============================================
VITE_ENABLE_IVR="true"
VITE_ENABLE_OFFLINE_MODE="true"
VITE_ENABLE_ANALYTICS="true"

# ============================================
# NOTES
# ============================================
#
# 1. PWA Settings:
#    - Ensure service worker is enabled
#    - Enable offline sync for disaster resilience
#    - Push notifications help with task alerts
#
# 2. API URLs:
#    - Must match backend Render deployment
#    - Update both VITE_API_URL and VITE_SOCKET_URL
#    - Test WebSocket connection on PWA
#
# 3. Offline Mode:
#    - Critical for disaster zones
#    - Enables full app usage without internet
#    - Changes queued and synced when online
#
# 4. Testing offline:
#    - Open DevTools (F12) → Network
#    - Click "Offline" checkbox
#    - App should continue working
#    - Uncheck to test sync
#
